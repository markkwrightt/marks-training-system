import React, { useState, useEffect, useMemo, useRef } from 'react';
import { 
  LineChart, Line, BarChart, Bar, XAxis, YAxis, CartesianGrid, Tooltip, ResponsiveContainer, ComposedChart, Legend,
  RadarChart, PolarGrid, PolarAngleAxis, PolarRadiusAxis, Radar, AreaChart, Area, Cell
} from 'recharts';
import { 
  Activity, Scale, Plus, TrendingUp, Dumbbell, Trash2, 
  HeartPulse, Move, Image as ImageIcon, Play, Save, X, ListPlus, ChevronRight, 
  Settings, Edit3, Trophy, User, Copy, CheckCircle2, Circle, Square, Download, Target,
  Apple, Search, Flame, Droplet, Wheat, Database, AlertCircle, ClipboardList, CalendarDays, Radio, Upload
} from 'lucide-react';

// --- INITIAL DATA SEEDING ---
const DEFAULT_EXERCISES = [
  { id: 'e1', name: 'Weighted Step-ups', category: 'weight', unit: 'kg', imgUrl: 'https://images.unsplash.com/photo-1584735935682-2f2b69dff9d2?w=150&q=80', desc: 'Crucial for jungle inclines. Load a backpack.' },
  { id: 'e2', name: 'Zone 2 Walk/Ruck', category: 'cardio', unit: 'min', imgUrl: 'https://images.unsplash.com/photo-1551632811-561732d1e306?w=150&q=80', desc: 'Maintain conversational pace to build aerobic base.' },
  { id: 'e3', name: 'Plank', category: 'mobility', unit: 'sec', imgUrl: 'https://images.unsplash.com/photo-1566241440091-ec10de8db2e1?w=150&q=80', desc: 'Core stability for carrying heavy packs.' },
  { id: 'e4', name: 'Goblet Squat', category: 'weight', unit: 'kg', imgUrl: '', desc: 'Builds quad strength and hip mobility.' }
];

const DEFAULT_ROUTINES = [
  { id: 'r1', name: 'Jungle Leg Prep', exercises: ['e1', 'e4', 'e3'] },
  { id: 'r2', name: 'Active Recovery', exercises: ['e2', 'e3'] }
];

const App = () => {
  // --- STATE MANAGEMENT ---
  const [activeTab, setActiveTab] = useState('dashboard');
  
  // Databases
  const [exercises, setExercises] = useState(() => {
    const saved = localStorage.getItem('marks_jr_exercises');
    return saved ? JSON.parse(saved) : DEFAULT_EXERCISES;
  });
  
  const [routines, setRoutines] = useState(() => {
    const saved = localStorage.getItem('marks_jr_routines');
    return saved ? JSON.parse(saved) : DEFAULT_ROUTINES;
  });

  const [logs, setLogs] = useState(() => {
    const saved = localStorage.getItem('marks_jr_logs');
    return saved ? JSON.parse(saved) : [];
  });
  
  const [metrics, setMetrics] = useState(() => {
    const saved = localStorage.getItem('marks_jr_metrics');
    return saved ? JSON.parse(saved) : [
      { date: '2024-02-01', weight: 118, fat: 35 }
    ];
  });

  const [nutritionLogs, setNutritionLogs] = useState(() => {
    const saved = localStorage.getItem('marks_jr_nutrition');
    return saved ? JSON.parse(saved) : [];
  });

  // UI State
  const [trainTabState, setTrainTabState] = useState('active'); 
  const [selectedExerciseId, setSelectedExerciseId] = useState(null);
  const [showAddExercise, setShowAddExercise] = useState(false);
  const [showAddRoutine, setShowAddRoutine] = useState(false);
  const [showDraftSelector, setShowDraftSelector] = useState(false);
  const [expandedRoutineId, setExpandedRoutineId] = useState(null);
  
  // Graph Filters
  const [dashFilter, setDashFilter] = useState('ALL');
  const [bodyFilter, setBodyFilter] = useState('ALL');
  const [nutriFilter, setNutriFilter] = useState('ALL');
  const [libFilter, setLibFilter] = useState('ALL');

  // Forms & Draft
  const [exerciseForm, setExerciseForm] = useState({ name: '', category: 'weight', unit: 'kg', imgUrl: '', desc: '', notes: '' });
  const [editingExerciseId, setEditingExerciseId] = useState(null);
  const [newRoutineForm, setNewRoutineForm] = useState({ name: '', exercises: [] });
  const [metricForm, setMetricForm] = useState({ 
    weight: '', fat: '', muscleMass: '', bodyFatMass: '', bmi: '', bmr: '',
    segLeanLArm: '', segLeanRArm: '', segLeanTrunk: '', segLeanLLeg: '', segLeanRLeg: '',
    segFatLArm: '', segFatRArm: '', segFatTrunk: '', segFatLLeg: '', segFatRLeg: ''
  });
  const [bodyTabState, setBodyTabState] = useState('log');
  const [nutritionTabState, setNutritionTabState] = useState('daily');
  
  // Date states
  const [workoutDate, setWorkoutDate] = useState(() => new Date().toISOString().split('T')[0]);
  const [nutritionDate, setNutritionDate] = useState(() => new Date().toISOString().split('T')[0]);

  const [dailyDraft, setDailyDraft] = useState(() => {
    const saved = localStorage.getItem('marks_jr_daily_draft');
    return saved ? JSON.parse(saved).map(item => ({...item, timerRunning: false})) : []; 
  });

  const [settings, setSettings] = useState(() => {
    const saved = localStorage.getItem('marks_jr_settings');
    return saved ? JSON.parse(saved) : {
      weeklyTarget: 3,
      mainName: 'Vietnam Jungle',
      mainDate: '2027-05-01',
      subName: 'Local Trial Hike',
      subDate: '2026-08-01',
      currentPhase: 'Base Building',
      height: 187,
      nutritionTargets: { calories: 2500, protein: 180, carbs: 220, fat: 80 },
      myzoneConnected: false
    };
  });
  const [showSettings, setShowSettings] = useState(false);

  // --- PERSISTENCE ---
  useEffect(() => localStorage.setItem('marks_jr_exercises', JSON.stringify(exercises)), [exercises]);
  useEffect(() => localStorage.setItem('marks_jr_routines', JSON.stringify(routines)), [routines]);
  useEffect(() => localStorage.setItem('marks_jr_logs', JSON.stringify(logs)), [logs]);
  useEffect(() => localStorage.setItem('marks_jr_metrics', JSON.stringify(metrics)), [metrics]);
  useEffect(() => localStorage.setItem('marks_jr_nutrition', JSON.stringify(nutritionLogs)), [nutritionLogs]);
  useEffect(() => localStorage.setItem('marks_jr_settings', JSON.stringify(settings)), [settings]);
  useEffect(() => localStorage.setItem('marks_jr_daily_draft', JSON.stringify(dailyDraft)), [dailyDraft]);

  // --- INLINE TIMER LOGIC ---
  useEffect(() => {
    const interval = setInterval(() => {
      setDailyDraft(draft => {
        if (!draft.some(item => item.timerRunning)) return draft;
        return draft.map(item => item.timerRunning ? { ...item, timerSeconds: (item.timerSeconds || 0) + 1 } : item);
      });
    }, 1000);
    return () => clearInterval(interval);
  }, []);

  const formatTimer = (seconds) => {
    const m = Math.floor(seconds / 60).toString().padStart(2, '0');
    const s = (seconds % 60).toString().padStart(2, '0');
    return `${m}:${s}`;
  };

  // --- CALCULATIONS & UTILS ---
  const filterByTime = (data, dateKey, filterValue) => {
    if (filterValue === 'ALL') return data;
    const past = new Date();
    if (filterValue === '1M') past.setMonth(past.getMonth() - 1);
    if (filterValue === '3M') past.setMonth(past.getMonth() - 3);
    if (filterValue === '6M') past.setMonth(past.getMonth() - 6);
    if (filterValue === '1Y') past.setFullYear(past.getFullYear() - 1);
    return data.filter(d => new Date(d[dateKey]) >= past);
  };

  const getPhase = (targetDateStr) => {
    const monthsLeft = (new Date(targetDateStr) - new Date()) / (1000 * 60 * 60 * 24 * 30);
    if (monthsLeft > 12) return 'Base Building';
    if (monthsLeft > 6) return 'Functional Strength';
    if (monthsLeft > 0) return 'Specific Prep';
    return 'Expedition Ready';
  };

  const daysUntil = (dateStr) => Math.max(0, Math.ceil((new Date(dateStr) - new Date()) / (1000 * 60 * 60 * 24)));
  
  const getBodyMassStats = (metric) => {
    if (!metric) return { weight: 0, fatMass: 0, muscleMass: 0 };
    const fatMass = metric.fat ? (metric.weight * (metric.fat / 100)) : 0;
    const muscleMass = metric.fat ? (metric.weight - fatMass) : 0;
    return { weight: metric.weight, fatMass, muscleMass };
  };

  const currentStats = getBodyMassStats(metrics[metrics.length - 1]);
  const initialStats = getBodyMassStats(metrics[0]);
  
  const changes = {
    weight: (currentStats.weight - initialStats.weight).toFixed(1),
    fatMass: (currentStats.fatMass - initialStats.fatMass).toFixed(1),
    muscleMass: (currentStats.muscleMass - initialStats.muscleMass).toFixed(1)
  };

  const currentWeekLogs = useMemo(() => {
    const today = new Date();
    const day = today.getDay();
    const diff = today.getDate() - day + (day === 0 ? -6 : 1);
    const monday = new Date(today.setDate(diff));
    monday.setHours(0,0,0,0);
    return logs.filter(log => new Date(log.date) >= monday);
  }, [logs]);
  
  const streak = new Set(currentWeekLogs.map(l => l.date)).size;

  const totalVolumes = useMemo(() => {
    let strength = 0, cardio = 0, mobility = 0, meps = 0;
    logs.forEach(log => {
      meps += (log.meps || 0);
      const ex = exercises.find(e => e.id === log.exerciseId);
      if (ex) {
        if (ex.category === 'weight') strength++;
        if (ex.category === 'cardio') cardio++;
        if (ex.category === 'mobility') mobility++;
      }
    });
    return { strength, cardio, mobility, meps };
  }, [logs, exercises]);

  const calculateDailyBurn = (dateStr) => {
    const dayLogs = logs.filter(l => l.date === dateStr);
    let burn = 0;
    dayLogs.forEach(log => {
       const ex = exercises.find(e => e.id === log.exerciseId);
       if (!ex) return;
       if (ex.category === 'cardio') burn += (log.value * 10);
       else if (ex.category === 'weight') burn += 15;
       else if (ex.category === 'mobility') burn += (log.value / 60) * 5;
    });
    return Math.round(burn);
  };

  const composedChartData = useMemo(() => {
    const dataMap = {};
    metrics.forEach(m => {
      const stats = getBodyMassStats(m);
      dataMap[m.date] = { date: m.date, weight: stats.weight, fatMass: stats.fatMass || null, muscleMass: stats.muscleMass || null, meps: 0 };
    });
    logs.forEach(l => {
      if (!dataMap[l.date]) dataMap[l.date] = { date: l.date, meps: 0 };
      dataMap[l.date].meps += (l.meps || 0);
      const ex = exercises.find(e => e.id === l.exerciseId);
      if (ex) {
         const catKey = ex.category === 'weight' ? 'strengthCount' : ex.category + 'Count';
         dataMap[l.date][catKey] = (dataMap[l.date][catKey] || 0) + 1;
      }
    });
    return filterByTime(Object.values(dataMap).sort((a,b) => new Date(a.date) - new Date(b.date)), 'date', dashFilter);
  }, [metrics, logs, exercises, dashFilter]);

  // PRO TRAINER ENGINE: GHOST SETS
  const getPreviousLog = (exId) => {
    const pastLogs = logs.filter(l => l.exerciseId === exId).sort((a,b) => new Date(b.date) - new Date(a.date));
    return pastLogs.length > 0 ? pastLogs[0] : null;
  };

  // --- HANDLERS ---
  const handleSaveExercise = (e) => {
    e.preventDefault();
    if (!exerciseForm.name) return;
    if (editingExerciseId) {
      setExercises(exercises.map(ex => ex.id === editingExerciseId ? { ...ex, ...exerciseForm } : ex));
    } else {
      setExercises([...exercises, { id: 'e' + Date.now(), ...exerciseForm }]);
    }
    setExerciseForm({ name: '', category: 'weight', unit: 'kg', imgUrl: '', desc: '', notes: '' });
    setShowAddExercise(false);
    setEditingExerciseId(null);
  };

  const handleImageUpload = (e) => {
    const file = e.target.files[0];
    if (file) {
      const reader = new FileReader();
      reader.onloadend = () => setExerciseForm({ ...exerciseForm, imgUrl: reader.result });
      reader.readAsDataURL(file);
    }
  };

  const deleteExercise = (id) => {
    if(window.confirm("Are you sure? This will remove the exercise from your library (past logs will remain safe).")) {
      setExercises(exercises.filter(ex => ex.id !== id));
      setSelectedExerciseId(null);
      setShowAddExercise(false);
      setEditingExerciseId(null);
    }
  };

  const deleteLog = (id) => {
    if(window.confirm("Delete this specific set?")) {
      setLogs(logs.filter(l => l.id !== id));
    }
  };

  const deleteMetric = (dateStr) => {
    if(window.confirm("Delete the body scan for this date?")) {
      setMetrics(metrics.filter(m => m.date !== dateStr));
    }
  };

  const handleSaveRoutine = (e) => {
    e.preventDefault();
    if (!newRoutineForm.name || newRoutineForm.exercises.length === 0) return;
    setRoutines([...routines, { id: 'r' + Date.now(), ...newRoutineForm }]);
    setNewRoutineForm({ name: '', exercises: [] });
    setShowAddRoutine(false);
  };

  const deleteRoutine = (e, id) => {
    e.stopPropagation();
    if(window.confirm("Delete this routine entirely?")) {
      setRoutines(routines.filter(r => r.id !== id));
    }
  };

  const toggleExerciseForRoutine = (exId) => {
    setNewRoutineForm(prev => ({
      ...prev,
      exercises: prev.exercises.includes(exId) 
        ? prev.exercises.filter(id => id !== exId)
        : [...prev.exercises, exId]
    }));
  };

  const loadRoutineToDraft = (routine) => {
    const newItems = routine.exercises.map(exId => ({
      tempId: Math.random().toString(36).substr(2, 9),
      exerciseId: exId,
      value: '', reps: '', meps: '', completed: false, timerRunning: false, timerSeconds: 0
    }));
    setDailyDraft(prev => [...prev, ...newItems]);
    setTrainTabState('active');
    setExpandedRoutineId(null);
  };

  const addExerciseToDraft = (exId) => {
    setDailyDraft(prev => [...prev, {
      tempId: Math.random().toString(36).substr(2, 9),
      exerciseId: exId,
      value: '', reps: '', meps: '', completed: false, timerRunning: false, timerSeconds: 0
    }]);
    setShowDraftSelector(false);
  };

  const duplicateDraftItem = (item) => {
    setDailyDraft(prev => [...prev, { ...item, tempId: Math.random().toString(36).substr(2, 9), completed: false, timerRunning: false, timerSeconds: 0 }]);
  };

  const updateDraftItem = (tempId, updates) => {
      setDailyDraft(prevDraft => prevDraft.map(item => item.tempId === tempId ? { ...item, ...updates } : item));
  };

  const toggleInlineTimer = (item, ex) => {
    if (item.timerRunning) {
      // STOP TIMER -> Auto-complete
      const isTimeBased = ex.unit === 'sec' || ex.unit === 'min';
      let autoValue = item.value;
      if (isTimeBased && item.timerSeconds > 0) {
        autoValue = ex.unit === 'sec' ? item.timerSeconds : (item.timerSeconds / 60).toFixed(1);
      }
      updateDraftItem(item.tempId, { timerRunning: false, completed: true, value: autoValue });
    } else {
      // START TIMER
      updateDraftItem(item.tempId, { timerRunning: true, completed: false });
    }
  };

  const toggleManualCompletion = (item) => {
    updateDraftItem(item.tempId, { completed: !item.completed, timerRunning: false });
  };

  const removeDraftItem = (tempId) => setDailyDraft(prev => prev.filter(item => item.tempId !== tempId));

  const saveDailyWorkout = () => {
    const completedLogs = dailyDraft.filter(item => item.completed && item.value);
    if (completedLogs.length === 0) {
      alert("Please check off (complete) at least one set with a value before saving.");
      return;
    }

    const newLogs = completedLogs.map(item => {
      const ex = exercises.find(e => e.id === item.exerciseId);
      
      // Auto-calculate MEPs if connected to Myzone and user left it blank
      let mepsScore = parseInt(item.meps);
      if (isNaN(mepsScore)) mepsScore = 0;
      
      if (mepsScore === 0 && settings.myzoneConnected && ex) {
        const val = parseFloat(item.value) || 0;
        if (ex.category === 'cardio') mepsScore = Math.round(val * (ex.unit==='min'? 4 : 4/60));
        else if (ex.category === 'weight') mepsScore = 2;
        else if (ex.category === 'mobility') mepsScore = Math.round(val * (ex.unit==='min'? 1 : 1/60)) || 1;
      }

      return {
        id: Date.now() + Math.random(),
        date: workoutDate,
        exerciseId: item.exerciseId,
        value: parseFloat(item.value) || 0,
        reps: item.reps || '',
        meps: mepsScore
      };
    });

    setLogs([...newLogs, ...logs]);
    setDailyDraft(prev => prev.filter(item => !item.completed));
  };

  const addMetric = (e) => {
    e.preventDefault();
    if (!metricForm.weight) return;
    const parse = (val) => val ? parseFloat(val) : null;
    setMetrics([...metrics, {
      date: new Date().toISOString().split('T')[0],
      weight: parse(metricForm.weight), fat: parse(metricForm.fat), muscleMass: parse(metricForm.muscleMass),
      bodyFatMass: parse(metricForm.bodyFatMass), bmi: parse(metricForm.bmi), bmr: parse(metricForm.bmr),
      segLeanLArm: parse(metricForm.segLeanLArm), segLeanRArm: parse(metricForm.segLeanRArm),
      segLeanTrunk: parse(metricForm.segLeanTrunk), segLeanLLeg: parse(metricForm.segLeanLLeg),
      segLeanRLeg: parse(metricForm.segLeanRLeg), segFatLArm: parse(metricForm.segFatLArm),
      segFatRArm: parse(metricForm.segFatRArm), segFatTrunk: parse(metricForm.segFatTrunk),
      segFatLLeg: parse(metricForm.segFatLLeg), segFatRLeg: parse(metricForm.segFatRLeg),
    }]);
    setMetricForm({ 
      weight: '', fat: '', muscleMass: '', bodyFatMass: '', bmi: '', bmr: '',
      segLeanLArm: '', segLeanRArm: '', segLeanTrunk: '', segLeanLLeg: '', segLeanRLeg: '',
      segFatLArm: '', segFatRArm: '', segFatTrunk: '', segFatLLeg: '', segFatRLeg: ''
    });
    setBodyTabState('history');
  };

  const exportData = () => {
    const data = { settings, exercises, routines, logs, metrics, nutritionLogs };
    const blob = new Blob([JSON.stringify(data, null, 2)], { type: 'application/json' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `FitnessTracker_Backup_${new Date().toISOString().split('T')[0]}.json`;
    a.click();
    URL.revokeObjectURL(url);
  };

  const importData = (e) => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (event) => {
      try {
        const data = JSON.parse(event.target.result);
        if (data.settings) setSettings(data.settings);
        if (data.exercises) setExercises(data.exercises);
        if (data.routines) setRoutines(data.routines);
        if (data.logs) setLogs(data.logs);
        if (data.metrics) setMetrics(data.metrics);
        if (data.nutritionLogs) setNutritionLogs(data.nutritionLogs);
        alert("Data successfully imported and restored!");
        setShowSettings(false);
      } catch (err) {
        alert("Error: Invalid backup file format.");
      }
    };
    reader.readAsText(file);
    e.target.value = null; // reset input
  };

  const getCategoryIcon = (cat) => {
    if (cat === 'weight') return <Dumbbell className="w-5 h-5" />;
    if (cat === 'cardio') return <HeartPulse className="w-5 h-5" />;
    return <Move className="w-5 h-5" />;
  };

  const getExerciseData = (exId) => {
    const exLogs = logs.filter(l => l.exerciseId === exId).sort((a,b) => new Date(a.date) - new Date(b.date));
    const grouped = exLogs.reduce((acc, log) => {
      const ex = exercises.find(e => e.id === exId);
      if (!acc[log.date]) {
        acc[log.date] = { ...log };
      } else {
        if (ex?.category === 'cardio') {
          acc[log.date].value += log.value; 
        } else {
          if (log.value > acc[log.date].value) acc[log.date] = { ...log }; 
        }
      }
      return acc;
    }, {});
    return filterByTime(Object.values(grouped), 'date', libFilter);
  };

  const TimeFilterSelect = ({ value, onChange }) => (
    <select value={value} onChange={e => onChange(e.target.value)} className="bg-slate-100 dark:bg-slate-800 text-xs font-bold text-slate-600 dark:text-slate-300 p-1.5 rounded-lg border-none outline-none cursor-pointer">
      <option value="1M">1 Month</option>
      <option value="3M">3 Months</option>
      <option value="6M">6 Months</option>
      <option value="1Y">1 Year</option>
      <option value="ALL">All Time</option>
    </select>
  );

  // --- SUB-COMPONENTS ---
  const Dashboard = () => (
    <div className="space-y-6 pb-24">
      {showSettings && (
        <div className="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 flex items-center justify-center p-4">
          <div className="bg-white dark:bg-slate-800 rounded-3xl p-6 w-full max-w-sm shadow-2xl border border-slate-100 dark:border-slate-700 max-h-[90vh] overflow-y-auto">
            <div className="flex justify-between items-center mb-4">
              <h3 className="font-bold text-lg">Settings & Backup</h3>
              <button onClick={() => setShowSettings(false)} className="text-slate-400 hover:text-rose-500"><X className="w-5 h-5"/></button>
            </div>
            
            <div className="space-y-4">
              <div className="bg-slate-50 dark:bg-slate-900 p-4 rounded-2xl flex items-center justify-between border border-slate-100 dark:border-slate-800">
                <div className="flex items-center gap-3">
                  <Radio className={`w-6 h-6 ${settings.myzoneConnected ? 'text-rose-500' : 'text-slate-400'}`} />
                  <div>
                    <h4 className="font-bold text-sm">Myzone Integration</h4>
                    <p className="text-[10px] text-slate-500">Track effort points (MEPs)</p>
                  </div>
                </div>
                <button 
                  onClick={() => setSettings({...settings, myzoneConnected: !settings.myzoneConnected})}
                  className={`relative w-12 h-6 rounded-full transition-colors ${settings.myzoneConnected ? 'bg-rose-500' : 'bg-slate-300 dark:bg-slate-700'}`}
                >
                  <div className={`absolute top-1 w-4 h-4 bg-white rounded-full transition-transform ${settings.myzoneConnected ? 'left-7' : 'left-1'}`}></div>
                </button>
              </div>

              <div className="pt-2 border-t border-slate-100 dark:border-slate-700">
                <label className="text-xs font-bold text-slate-500 uppercase">Weekly Target (Days)</label>
                <input type="number" value={settings.weeklyTarget} onChange={e => setSettings({...settings, weeklyTarget: e.target.value})} className="w-full p-3 rounded-xl bg-slate-50 dark:bg-slate-900 mt-1" />
              </div>
              <div className="pt-2 border-t border-slate-100 dark:border-slate-700">
                <label className="text-xs font-bold text-emerald-500 uppercase">Main Target</label>
                <input type="text" value={settings.mainName} onChange={e => setSettings({...settings, mainName: e.target.value})} className="w-full p-3 rounded-xl bg-slate-50 dark:bg-slate-900 mt-1 mb-2" placeholder="Target Name" />
                <input type="date" value={settings.mainDate} onChange={e => setSettings({...settings, mainDate: e.target.value})} className="w-full p-3 rounded-xl bg-slate-50 dark:bg-slate-900 mb-2" />
                <select value={settings.currentPhase || 'Base Building'} onChange={e => setSettings({...settings, currentPhase: e.target.value})} className="w-full p-3 rounded-xl bg-slate-50 dark:bg-slate-900">
                  <option value="Base Building">Base Building</option>
                  <option value="Functional Strength">Functional Strength</option>
                  <option value="Specific Prep">Specific Prep</option>
                  <option value="Expedition Ready">Expedition Ready</option>
                </select>
              </div>
              <div className="pt-2 border-t border-slate-100 dark:border-slate-700">
                <label className="text-xs font-bold text-blue-500 uppercase">Sub Target</label>
                <input type="text" value={settings.subName || ''} onChange={e => setSettings({...settings, subName: e.target.value})} className="w-full p-3 rounded-xl bg-slate-50 dark:bg-slate-900 mt-1 mb-2" placeholder="Sub Target Name (e.g. Local Hike)" />
                <input type="date" value={settings.subDate || ''} onChange={e => setSettings({...settings, subDate: e.target.value})} className="w-full p-3 rounded-xl bg-slate-50 dark:bg-slate-900" />
              </div>
              <div className="pt-2 border-t border-slate-100 dark:border-slate-700">
