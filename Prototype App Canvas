                  <input placeholder="L. Leg" value={metricForm.segFatLLeg} onChange={e => setMetricForm({...metricForm, segFatLLeg: e.target.value})} className="absolute bottom-6 left-2 w-16 p-2 text-center rounded-xl border-2 border-rose-200 dark:border-rose-800 bg-white dark:bg-slate-800 text-xs font-bold focus:ring-2 ring-rose-500 outline-none z-10 shadow-sm" />
                  <input placeholder="R. Leg" value={metricForm.segFatRLeg} onChange={e => setMetricForm({...metricForm, segFatRLeg: e.target.value})} className="absolute bottom-6 right-2 w-16 p-2 text-center rounded-xl border-2 border-rose-200 dark:border-rose-800 bg-white dark:bg-slate-800 text-xs font-bold focus:ring-2 ring-rose-500 outline-none z-10 shadow-sm" />
                </div>
              </div>

              <button type="submit" className="w-full bg-blue-600 text-white p-4 rounded-2xl font-black shadow-lg shadow-blue-500/30 hover:bg-blue-700 transition-colors">Save Complete Scan</button>
            </form>
          </div>
        )}

        {bodyTabState === 'history' && (
          <div className="bg-white dark:bg-slate-800 p-6 rounded-3xl shadow-sm border border-slate-100 dark:border-slate-700">
            <h4 className="font-bold mb-4 flex items-center gap-2"><ListPlus className="w-5 h-5 text-emerald-500" /> Measurement History</h4>
            <div className="space-y-4">
              {metrics.slice().reverse().map((m, i) => (
                <div key={i} className="bg-slate-50 dark:bg-slate-900 p-5 rounded-2xl border border-slate-100 dark:border-slate-800 relative group">
                  <div className="flex justify-between items-center mb-3 border-b border-slate-200 dark:border-slate-700 pb-2">
                    <span className="text-sm font-black text-slate-600 dark:text-slate-300">{m.date}</span>
                    <div className="flex items-center gap-2">
                      {m.bmi && <span className="text-xs font-bold bg-amber-100 text-amber-700 px-2 py-1 rounded-lg">BMI: {m.bmi}</span>}
                      <button onClick={() => deleteMetric(m.date)} className="text-slate-300 hover:text-rose-500 p-1 opacity-0 group-hover:opacity-100 transition-opacity"><Trash2 className="w-4 h-4" /></button>
                    </div>
                  </div>
                  <div className="grid grid-cols-3 gap-2">
                    <div className="text-center">
                      <p className="text-[10px] font-bold text-slate-400 uppercase">Weight</p>
                      <p className="font-black text-slate-800 dark:text-white">{m.weight}<span className="text-xs text-slate-400 ml-0.5">kg</span></p>
                    </div>
                    <div className="text-center border-l border-r border-slate-200 dark:border-slate-700">
                      <p className="text-[10px] font-bold text-slate-400 uppercase">Body Fat</p>
                      <p className="font-black text-rose-500">{m.fat ? `${m.fat}%` : '--'}</p>
                    </div>
                    <div className="text-center">
                      <p className="text-[10px] font-bold text-slate-400 uppercase">Muscle</p>
                      <p className="font-black text-emerald-600">{m.muscleMass ? `${m.muscleMass}kg` : '--'}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}

        {bodyTabState === 'analytics' && (
          <div className="space-y-6">
             <div className="bg-white dark:bg-slate-800 p-6 rounded-3xl shadow-sm border border-slate-100 dark:border-slate-700">
                <div className="flex justify-between items-center mb-4">
                  <h3 className="font-bold text-slate-800 dark:text-white flex items-center gap-2">
                    <TrendingUp className="w-5 h-5 text-emerald-500" /> Body Fat % Trend
                  </h3>
                  <TimeFilterSelect value={bodyFilter} onChange={setBodyFilter} />
                </div>
                <div className="h-56 w-full">
                  <ResponsiveContainer width="100%" height="100%">
                    <AreaChart data={filteredMetrics.filter(m => m.fat)}>
                      <defs>
                        <linearGradient id="colorFat" x1="0" y1="0" x2="0" y2="1">
                          <stop offset="5%" stopColor="#f43f5e" stopOpacity={0.3}/>
                          <stop offset="95%" stopColor="#f43f5e" stopOpacity={0}/>
                        </linearGradient>
                      </defs>
                      <CartesianGrid strokeDasharray="3 3" vertical={false} stroke="#f1f5f9" />
                      <XAxis dataKey="date" tick={{fontSize: 10}} tickMargin={10} />
                      <YAxis domain={['dataMin - 2', 'dataMax + 2']} tick={{fontSize: 10}} axisLine={false} tickLine={false} />
                      <Tooltip contentStyle={{ borderRadius: '12px', border: 'none', fontSize: '12px' }} />
                      <Area type="monotone" dataKey="fat" name="Body Fat %" stroke="#f43f5e" strokeWidth={3} fillOpacity={1} fill="url(#colorFat)" />
                    </AreaChart>
                  </ResponsiveContainer>
                </div>
             </div>

             <div className="bg-white dark:bg-slate-800 p-6 rounded-3xl shadow-sm border border-slate-100 dark:border-slate-700">
                <h3 className="font-bold text-slate-800 dark:text-white mb-4 flex items-center gap-2">
                  <User className="w-5 h-5 text-purple-500" /> Latest Segmental Balance
                </h3>
                <p className="text-xs text-slate-500 mb-2">Compares Left vs Right (Lean & Fat)</p>
                <div className="h-72 w-full -ml-4">
                  <ResponsiveContainer width="100%" height="100%">
                    <RadarChart cx="50%" cy="50%" outerRadius="70%" data={radarData}>
                      <PolarGrid stroke="#e2e8f0" />
                      <PolarAngleAxis dataKey="subject" tick={{fontSize: 10, fill: '#64748b', fontWeight: 'bold'}} />
                      <PolarRadiusAxis angle={30} domain={[0, 'auto']} tick={{fontSize: 8}} />
                      <Radar name="Lean Mass (kg)" dataKey="lean" stroke="#10b981" fill="#10b981" fillOpacity={0.4} />
                      <Radar name="Fat Mass (kg)" dataKey="fat" stroke="#f43f5e" fill="#f43f5e" fillOpacity={0.4} />
                      <Legend wrapperStyle={{ fontSize: '10px', paddingTop: '10px' }} />
                      <Tooltip contentStyle={{ borderRadius: '12px', border: 'none', fontSize: '12px' }} />
                    </RadarChart>
                  </ResponsiveContainer>
                </div>
             </div>
          </div>
        )}
      </div>
    );
  };

  const NutritionTab = () => {
    const targets = settings.nutritionTargets || { calories: 2500, protein: 180, carbs: 220, fat: 80 };
    
    // Nutrition UI States
    const [searchQuery, setSearchQuery] = useState('');
    const [searchResults, setSearchResults] = useState([]);
    const [isSearching, setIsSearching] = useState(false);
    const [selectedFood, setSelectedFood] = useState(null);
    const [servingAmount, setServingAmount] = useState('');

    const todayLogs = nutritionLogs.filter(n => n.date === nutritionDate);
    const dailyTotals = todayLogs.reduce((acc, curr) => {
      return {
        calories: acc.calories + curr.calories,
        protein: acc.protein + curr.protein,
        carbs: acc.carbs + curr.carbs,
        fat: acc.fat + curr.fat
      };
    }, { calories: 0, protein: 0, carbs: 0, fat: 0 });

    // Net Calories considering training burn
    const dailyBurn = calculateDailyBurn(nutritionDate);
    const netCalories = dailyTotals.calories - dailyBurn;

    // The API Search Engine
    const handleSearch = async (e) => {
      e.preventDefault();
      if (!searchQuery.trim()) return;
      setIsSearching(true);
      
      try {
        const res = await fetch(`https://world.openfoodfacts.org/cgi/search.pl?search_terms=${encodeURIComponent(searchQuery)}&search_simple=1&action=process&json=1&page_size=15`);
        const data = await res.json();
        
        const mapped = data.products
          .filter(p => p.nutriments && p.nutriments['energy-kcal_100g']) 
          .map(p => ({
             id: p.code || Math.random().toString(),
             name: p.product_name || searchQuery,
             brand: p.brands || 'Generic',
             calories_100g: p.nutriments['energy-kcal_100g'] || 0,
             protein_100g: p.nutriments.proteins_100g || 0,
             carbs_100g: p.nutriments.carbohydrates_100g || 0,
             fat_100g: p.nutriments.fat_100g || 0,
          }));
        
        setSearchResults(mapped.length === 0 ? [] : mapped);
      } catch(err) {
        console.error("API Search failed", err);
        setSearchResults([]);
      }
      setIsSearching(false);
    };

    const handleAddFood = (e) => {
      e.preventDefault();
      if (!selectedFood) return;
      
      let newLog;

      if (selectedFood.id === 'manual_direct') {
        newLog = {
          id: Date.now() + Math.random(),
          date: nutritionDate,
          name: selectedFood.name || 'Custom Meal',
          brand: 'Manual Entry',
          servingAmount: 1, // Represents 1 meal/entry
          calories: Number(selectedFood.calories_100g) || 0,
          protein: Number(selectedFood.protein_100g) || 0,
          carbs: Number(selectedFood.carbs_100g) || 0,
          fat: Number(selectedFood.fat_100g) || 0,
        };
      } else {
        if(!servingAmount) return;
        const multiplier = Number(servingAmount) / 100;
        newLog = {
          id: Date.now() + Math.random(),
          date: nutritionDate,
          name: selectedFood.name,
          brand: selectedFood.brand,
          servingAmount: Number(servingAmount),
          calories: Math.round(selectedFood.calories_100g * multiplier),
          protein: Math.round(selectedFood.protein_100g * multiplier),
          carbs: Math.round(selectedFood.carbs_100g * multiplier),
          fat: Math.round(selectedFood.fat_100g * multiplier),
        };
      }

      setNutritionLogs([newLog, ...nutritionLogs]);
      setSelectedFood(null);
      setSearchQuery('');
      setSearchResults([]);
      setServingAmount('');
    };

    const deleteNutritionLog = (id) => {
      setNutritionLogs(nutritionLogs.filter(n => n.id !== id));
    };

    // Analytics Data Prep
    const nutritionChartData = useMemo(() => {
      const dataMap = {};
      nutritionLogs.forEach(log => {
        if (!dataMap[log.date]) {
          dataMap[log.date] = { date: log.date, calories: 0 };
        }
        dataMap[log.date].calories += log.calories;
      });
      return filterByTime(Object.values(dataMap).sort((a,b) => new Date(a.date) - new Date(b.date)), 'date', nutriFilter);
    }, [nutritionLogs, nutriFilter]);

    const MacroBar = ({ label, current, target, colorClass, bgClass, icon: Icon }) => {
      const isOver = current > target;
      const percent = Math.min(100, (current / target) * 100);
      const activeColor = isOver ? 'bg-rose-500' : colorClass;
      const activeText = isOver ? 'text-rose-500' : colorClass.replace('bg-', 'text-');
      
      return (
        <div className="bg-slate-50 dark:bg-slate-900 p-3 rounded-2xl border border-transparent transition-colors" style={isOver ? {borderColor: '#f43f5e33'} : {}}>
          <div className="flex justify-between items-center mb-1">
            <div className="flex items-center gap-1">
              <Icon className={`w-3 h-3 ${activeText}`} />
              <span className={`text-[10px] uppercase font-bold ${isOver ? 'text-rose-500' : 'text-slate-500'}`}>{label}</span>
            </div>
            <span className="text-xs font-black">{Math.round(current)}<span className="text-[10px] text-slate-400 font-normal">/{target}g</span></span>
          </div>
          <div className={`h-2 w-full rounded-full ${bgClass} overflow-hidden`}>
            <div className={`h-full ${activeColor} rounded-full transition-all duration-500`} style={{width: `${percent}%`}}></div>
          </div>
        </div>
      );
    };

    return (
      <div className="space-y-6 pb-24">
        <div className="flex bg-slate-100 dark:bg-slate-800 p-1 rounded-2xl mb-4">
          <button onClick={() => setNutritionTabState('daily')} className={`flex-1 py-2 text-sm font-bold rounded-xl transition-all ${nutritionTabState === 'daily' ? 'bg-white dark:bg-slate-700 shadow-sm text-rose-600 dark:text-rose-400' : 'text-slate-500'}`}>Daily Log</button>
          <button onClick={() => setNutritionTabState('analytics')} className={`flex-1 py-2 text-sm font-bold rounded-xl transition-all ${nutritionTabState === 'analytics' ? 'bg-white dark:bg-slate-700 shadow-sm text-blue-600 dark:text-blue-400' : 'text-slate-500'}`}>Trends</button>
        </div>

        {nutritionTabState === 'daily' && (
          <>
            <div className="flex justify-between items-center mb-2">
              <h2 className="text-xl font-black text-slate-800 dark:text-white">Daily Intake</h2>
              <input 
                type="date" 
                value={nutritionDate} 
                onChange={(e) => setNutritionDate(e.target.value)} 
                className="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl px-3 py-1.5 text-sm font-bold text-slate-600 dark:text-slate-300"
              />
            </div>

            {/* Daily Summary Hero */}
            <div className="bg-white dark:bg-slate-800 p-5 rounded-3xl shadow-sm border border-slate-100 dark:border-slate-700">
              <div className="flex justify-between items-end mb-4 border-b border-slate-100 dark:border-slate-700 pb-4">
                <div>
                  <p className="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1 flex items-center gap-1"><Flame className="w-4 h-4 text-rose-500"/> Calories</p>
                  <h3 className="text-4xl font-black text-slate-800 dark:text-white leading-none">{Math.round(dailyTotals.calories)}</h3>
                  {dailyBurn > 0 && <p className="text-xs font-bold mt-2 text-blue-500">Net: {netCalories} kcal (-{dailyBurn} active)</p>}
                </div>
                <div className="text-right">
                  <div className={`inline-flex items-center justify-center w-16 h-16 rounded-full border-4 ${dailyTotals.calories > targets.calories ? 'border-rose-500 bg-rose-50 dark:bg-rose-900/20 text-rose-600' : 'border-emerald-500 bg-emerald-50 dark:bg-emerald-900/20 text-emerald-600'}`}>
                    <span className="text-sm font-black">{Math.abs(targets.calories - dailyTotals.calories)}</span>
                  </div>
                  <p className="text-[10px] uppercase font-bold text-slate-400 mt-1">{dailyTotals.calories > targets.calories ? 'Over Goal' : 'Remaining'}</p>
                </div>
              </div>
              <div className="grid grid-cols-3 gap-2">
                <MacroBar label="Protein" current={dailyTotals.protein} target={targets.protein} colorClass="bg-emerald-500" bgClass="bg-emerald-100 dark:bg-emerald-900/30" icon={Database} />
                <MacroBar label="Carbs" current={dailyTotals.carbs} target={targets.carbs} colorClass="bg-blue-500" bgClass="bg-blue-100 dark:bg-blue-900/30" icon={Wheat} />
                <MacroBar label="Fat" current={dailyTotals.fat} target={targets.fat} colorClass="bg-amber-500" bgClass="bg-amber-100 dark:bg-amber-900/30" icon={Droplet} />
              </div>
            </div>

            {/* Food Search / Entry Engine */}
            <div className="bg-white dark:bg-slate-800 p-5 rounded-3xl shadow-sm border border-slate-100 dark:border-slate-700">
              <h4 className="font-bold mb-3 flex items-center gap-2"><Search className="w-4 h-4 text-slate-400" /> Log Food</h4>
              
              {!selectedFood ? (
                <div>
                  <form onSubmit={handleSearch} className="flex gap-2 mb-3">
                    <input 
                      type="text" placeholder="Search database..." 
                      value={searchQuery} onChange={e => setSearchQuery(e.target.value)}
                      className="flex-1 p-3 rounded-xl bg-slate-50 dark:bg-slate-900 border-none outline-none focus:ring-2 ring-rose-500 text-sm"
                    />
                    <button type="submit" disabled={isSearching} className="bg-rose-600 text-white px-4 rounded-xl font-bold hover:bg-rose-700 disabled:opacity-50">
                      {isSearching ? '...' : 'Find'}
                    </button>
                    <button type="button" onClick={() => setSelectedFood({ id:'manual_direct', name:'', calories_100g:0, protein_100g:0, carbs_100g:0, fat_100g:0 })} className="bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 px-3 rounded-xl font-bold hover:bg-slate-200 transition-colors text-sm">
                      Custom
                    </button>
                  </form>
                  
                  {searchResults.length > 0 && (
                    <div className="border border-slate-100 dark:border-slate-700 rounded-xl overflow-hidden max-h-60 overflow-y-auto">
                      {searchResults.map((result, idx) => (
                        <div key={idx} onClick={() => setSelectedFood(result)} className="p-3 border-b border-slate-50 dark:border-slate-700 last:border-0 hover:bg-slate-50 dark:hover:bg-slate-900 cursor-pointer flex justify-between items-center transition-colors">
                          <div>
                            <p className="font-bold text-sm text-slate-800 dark:text-slate-200">{result.name}</p>
                            <p className="text-[10px] text-slate-500 uppercase">{result.brand} • per 100g</p>
                          </div>
                          <div className="text-right text-xs">
                            <span className="font-black text-rose-500">{result.calories_100g} kcal</span>
                            <p className="text-[10px] text-slate-400">P:{result.protein_100g} C:{result.carbs_100g} F:{result.fat_100g}</p>
                          </div>
                        </div>
                      ))}
                    </div>
                  )}
                </div>
              ) : (
                <form onSubmit={handleAddFood} className="bg-slate-50 dark:bg-slate-900 p-4 rounded-2xl border border-rose-100 dark:border-rose-900/30">
                  <div className="flex justify-between items-start mb-4">
                    <div>
                      <h4 className="font-black text-lg text-slate-800 dark:text-white leading-tight">{selectedFood.id === 'manual_direct' ? 'Custom Meal Entry' : selectedFood.name}</h4>
                      {selectedFood.id !== 'manual_direct' && <p className="text-xs text-slate-500">{selectedFood.brand}</p>}
                    </div>
                    <button type="button" onClick={() => setSelectedFood(null)} className="text-slate-400 hover:text-rose-500 bg-white dark:bg-slate-800 p-1.5 rounded-full shadow-sm"><X className="w-4 h-4"/></button>
                  </div>

                  {selectedFood.id === 'manual_direct' ? (
                    <div className="space-y-3">
                      <input type="text" required placeholder="Meal Name (e.g. Grandma's Pasta)" value={selectedFood.name || ''} onChange={e => setSelectedFood({...selectedFood, name: e.target.value})} className="w-full p-3 rounded-xl bg-white dark:bg-slate-800 font-bold" />
                      <input type="number" required placeholder="Total Calories" value={selectedFood.calories_100g || ''} onChange={e => setSelectedFood({...selectedFood, calories_100g: Number(e.target.value)})} className="w-full p-3 rounded-xl bg-white dark:bg-slate-800 font-bold text-rose-500" />
                      <div className="grid grid-cols-3 gap-2">
                        <input type="number" placeholder="Protein (g)" value={selectedFood.protein_100g || ''} onChange={e => setSelectedFood({...selectedFood, protein_100g: Number(e.target.value)})} className="w-full p-2 text-center rounded-xl bg-white dark:bg-slate-800 text-sm font-bold text-emerald-500" />
                        <input type="number" placeholder="Carbs (g)" value={selectedFood.carbs_100g || ''} onChange={e => setSelectedFood({...selectedFood, carbs_100g: Number(e.target.value)})} className="w-full p-2 text-center rounded-xl bg-white dark:bg-slate-800 text-sm font-bold text-blue-500" />
                        <input type="number" placeholder="Fat (g)" value={selectedFood.fat_100g || ''} onChange={e => setSelectedFood({...selectedFood, fat_100g: Number(e.target.value)})} className="w-full p-2 text-center rounded-xl bg-white dark:bg-slate-800 text-sm font-bold text-amber-500" />
                      </div>
                    </div>
                  ) : (
                    <div className="flex gap-2">
                      <div className="flex-1 relative">
                        <input 
                          type="number" required autoFocus placeholder="Amount in Grams (g)" 
                          value={servingAmount} onChange={e => setServingAmount(e.target.value)}
                          className="w-full p-4 rounded-xl bg-white dark:bg-slate-800 border-none focus:ring-2 ring-rose-500 font-black text-lg pr-12"
                        />
                        <span className="absolute right-4 top-1/2 -translate-y-1/2 font-bold text-slate-400">g</span>
                      </div>
                    </div>
                  )}

                  <button type="submit" className="w-full bg-rose-600 text-white p-3 rounded-xl font-bold mt-4 shadow-lg shadow-rose-500/30 flex items-center justify-center gap-2">
                    <Plus className="w-5 h-5"/> Add to Diary
                  </button>
                </form>
              )}
            </div>

            {/* Daily Log Feed */}
            <div className="space-y-3">
              <h4 className="font-bold text-slate-800 dark:text-white px-2 mt-2">Food Diary</h4>
              {todayLogs.length === 0 ? (
                <div className="text-center p-6 bg-slate-50 dark:bg-slate-900 border-2 border-dashed border-slate-200 dark:border-slate-800 rounded-3xl text-slate-400 font-medium">
                  No food logged today.
                </div>
              ) : (
                todayLogs.slice().reverse().map((log) => (
                  <div key={log.id} className="bg-white dark:bg-slate-800 p-4 rounded-2xl shadow-sm flex items-center justify-between group">
                    <div>
                      <h4 className="font-bold text-slate-800 dark:text-slate-200 leading-tight">{log.name}</h4>
                      <p className="text-[10px] text-slate-500 uppercase tracking-wider">{log.brand} • {log.servingAmount}{log.brand === 'Manual Entry' ? ' serv' : 'g'}</p>
                    </div>
                    <div className="flex items-center gap-3">
                      <div className="text-right">
                        <span className="font-black text-rose-500 block leading-none">{log.calories} <span className="text-[10px] font-normal text-slate-400 uppercase">kcal</span></span>
                        <span className="text-[10px] font-bold text-slate-400">P:{log.protein} C:{log.carbs} F:{log.fat}</span>
                      </div>
                      <button onClick={() => deleteNutritionLog(log.id)} className="text-slate-300 hover:text-rose-500 p-1 opacity-0 group-hover:opacity-100 transition-opacity"><Trash2 className="w-4 h-4" /></button>
                    </div>
                  </div>
                ))
              )}
            </div>
          </>
        )}

        {nutritionTabState === 'analytics' && (
          <div className="space-y-6">
            <div className="bg-white dark:bg-slate-800 p-6 rounded-3xl shadow-sm border border-slate-100 dark:border-slate-700">
              <div className="flex justify-between items-center mb-4">
                <h3 className="font-bold text-slate-800 dark:text-white flex items-center gap-2">
                  <Target className="w-5 h-5 text-blue-500" /> Intake vs Target
                </h3>
                <TimeFilterSelect value={nutriFilter} onChange={setNutriFilter} />
              </div>
              <p className="text-xs text-slate-500 mb-4 leading-relaxed">
                Bars represent daily calories. Green indicates a deficit or target met. Red indicates a caloric surplus. The dashed line is your target of <span className="font-bold text-slate-700 dark:text-slate-300">{targets.calories} kcal</span>.
              </p>
              
              <div className="h-64 w-full">
                <ResponsiveContainer width="100%" height="100%">
                  <ComposedChart data={nutritionChartData}>
                    <CartesianGrid strokeDasharray="3 3" vertical={false} stroke="#f1f5f9" />
                    <XAxis dataKey="date" tick={{fontSize: 10}} tickMargin={10} />
                    <YAxis domain={[0, 'dataMax + 500']} tick={{fontSize: 10}} axisLine={false} tickLine={false} />
                    <Tooltip contentStyle={{ borderRadius: '12px', border: 'none', fontSize: '12px' }} cursor={{fill: 'transparent'}} />
                    <Line type="step" dataKey={() => targets.calories} name="Target" stroke="#64748b" strokeWidth={2} strokeDasharray="5 5" dot={false} isAnimationActive={false} />
                    <Bar dataKey="calories" name="Consumed" radius={[4, 4, 0, 0]}>
                      {nutritionChartData.map((entry, index) => (
                        <Cell key={`cell-${index}`} fill={entry.calories > targets.calories ? '#f43f5e' : '#10b981'} />
                      ))}
                    </Bar>
                  </ComposedChart>
                </ResponsiveContainer>
              </div>
            </div>
          </div>
        )}
      </div>
    );
  };

  // THE NEW PT REVIEW TAB
  const ReportTab = () => {
    const [weekOffset, setWeekOffset] = useState(0);

    const last7Days = useMemo(() => {
      const days = [];
      for(let i=0; i<7; i++) {
         const d = new Date();
         d.setDate(d.getDate() - i - (weekOffset * 7));
         days.push(d.toISOString().split('T')[0]);
      }
      return days;
    }, [weekOffset]);

    // Calculate rolling 7-day averages
    const averages = useMemo(() => {
      let totalCals = 0, totalPro = 0, weightSum = 0, weightCount = 0, workoutDays = 0, totalMeps = 0;
      
      last7Days.forEach(date => {
        const dayNut = nutritionLogs.filter(n => n.date === date);
        totalCals += dayNut.reduce((acc, curr) => acc + curr.calories, 0);
        totalPro += dayNut.reduce((acc, curr) => acc + curr.protein, 0);
        
        const dayLogs = logs.filter(l => l.date === date);
        if (dayLogs.length > 0) workoutDays++;
        if (settings.myzoneConnected) totalMeps += dayLogs.reduce((acc, curr) => acc + (curr.meps || 0), 0);

        const metric = metrics.find(m => m.date === date);
        if (metric && metric.weight) { weightSum += metric.weight; weightCount++; }
      });

      return {
        calAvg: Math.round(totalCals / 7),
        proAvg: Math.round(totalPro / 7),
        weightAvg: weightCount > 0 ? (weightSum / weightCount).toFixed(1) : '--',
        workoutDays,
        totalMeps
      };
    }, [last7Days, nutritionLogs, logs, metrics, settings.myzoneConnected]);

    return (
      <div className="space-y-6 pb-24">
        {/* 7-Day Averages Header */}
        <div className="bg-gradient-to-br from-indigo-600 to-purple-900 rounded-3xl p-6 text-white shadow-xl relative overflow-hidden">
          <CalendarDays className="absolute -right-4 -top-4 w-32 h-32 opacity-10 rotate-12" />
          <div className="relative z-10">
            <div className="flex justify-between items-center mb-4">
              <p className="text-indigo-100 text-xs font-bold uppercase tracking-widest">7-Day Trainer Summary</p>
              <div className="flex gap-2">
                 <button onClick={() => setWeekOffset(w => w + 1)} className="bg-white/10 hover:bg-white/20 p-1.5 rounded-lg text-xs font-bold backdrop-blur-sm transition-colors">&larr; Prev</button>
                 {weekOffset > 0 && <button onClick={() => setWeekOffset(w => Math.max(0, w - 1))} className="bg-white/10 hover:bg-white/20 p-1.5 rounded-lg text-xs font-bold backdrop-blur-sm transition-colors">Next &rarr;</button>}
              </div>
            </div>
            <div className="grid grid-cols-2 gap-4">
              <div>
                <p className="text-[10px] text-indigo-200 uppercase font-bold">Avg Calories</p>
                <p className="text-2xl font-black">{averages.calAvg} <span className="text-xs font-medium">kcal</span></p>
              </div>
              <div>
                <p className="text-[10px] text-indigo-200 uppercase font-bold">Avg Protein</p>
                <p className="text-2xl font-black">{averages.proAvg} <span className="text-xs font-medium">g</span></p>
              </div>
              <div>
                <p className="text-[10px] text-indigo-200 uppercase font-bold">Training Days</p>
                <p className="text-2xl font-black text-emerald-300">{averages.workoutDays} <span className="text-xs font-medium text-indigo-100">/ 7</span></p>
              </div>
              <div>
                <p className="text-[10px] text-indigo-200 uppercase font-bold">Avg Weight</p>
                <p className="text-2xl font-black">{averages.weightAvg} <span className="text-xs font-medium">kg</span></p>
              </div>
              {settings.myzoneConnected && (
                <div className="col-span-2 border-t border-white/20 pt-3 mt-1">
                  <p className="text-[10px] text-rose-200 uppercase font-bold flex items-center gap-1"><Radio className="w-3 h-3"/> MEPs (7 Days)</p>
                  <p className="text-2xl font-black text-rose-400">{averages.totalMeps}</p>
                </div>
              )}
            </div>
          </div>
        </div>

        {/* Daily Audit Log */}
        <h3 className="font-black text-xl text-slate-800 dark:text-white px-2 mt-4">Audit Log</h3>
        
        <div className="space-y-4">
          {last7Days.map(dateStr => {
            const dayNut = nutritionLogs.filter(n => n.date === dateStr);
            const dayCals = dayNut.reduce((a, c) => a + c.calories, 0);
            const dayPro = dayNut.reduce((a, c) => a + c.protein, 0);
            const dayWorkouts = logs.filter(l => l.date === dateStr);
            const dayMetric = metrics.slice().reverse().find(m => m.date === dateStr);
            const dayBurn = calculateDailyBurn(dateStr);
            const dayMeps = dayWorkouts.reduce((a, c) => a + (c.meps || 0), 0);

            // Group exercises to look cleaner
            const groupedWorkouts = dayWorkouts.reduce((acc, log) => {
              if(!acc[log.exerciseId]) acc[log.exerciseId] = { count: 0, ex: exercises.find(e=>e.id===log.exerciseId) };
              acc[log.exerciseId].count++;
              return acc;
            }, {});

            return (
              <div key={dateStr} className="bg-white dark:bg-slate-800 rounded-3xl shadow-sm border border-slate-100 dark:border-slate-700 overflow-hidden">
                <div className="bg-slate-50 dark:bg-slate-900/50 px-5 py-3 border-b border-slate-100 dark:border-slate-700 flex justify-between items-center">
                  <span className="font-bold text-slate-700 dark:text-slate-300 text-sm">{new Date(dateStr).toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' })}</span>
                  {dayMetric && dayMetric.weight && <span className="text-xs font-bold bg-blue-100 text-blue-700 px-2 py-1 rounded-lg">{dayMetric.weight} kg</span>}
                </div>
                
                <div className="p-5 space-y-4">
                  {/* Diet Snapshot */}
                  <div className="flex items-center justify-between">
                    <div className="flex items-center gap-2">
                      <Apple className="w-4 h-4 text-rose-500" />
                      <span className="text-sm font-bold text-slate-600 dark:text-slate-400">Diet</span>
                    </div>
                    {dayCals > 0 ? (
                      <div className="text-right">
                        <span className={`font-black text-sm ${dayCals > settings.nutritionTargets?.calories ? 'text-rose-500' : 'text-emerald-500'}`}>{dayCals} kcal</span>
                        <span className="text-xs font-bold text-slate-400 ml-2">P: {dayPro}g</span>
                      </div>
                    ) : (
                      <span className="text-xs font-medium text-slate-400 italic">No data logged</span>
                    )}
                  </div>

                  {/* Training Snapshot */}
                  <div className="border-t border-slate-50 dark:border-slate-700/50 pt-4">
                    <div className="flex items-center justify-between mb-2">
                      <div className="flex items-center gap-2">
                        <Activity className="w-4 h-4 text-emerald-500" />
                        <span className="text-sm font-bold text-slate-600 dark:text-slate-400">Training</span>
                      </div>
                      {dayWorkouts.length > 0 && (
                        <div className="flex gap-2">
                          <span className="text-[10px] font-bold bg-emerald-50 dark:bg-emerald-900/20 text-emerald-600 px-2 py-1 rounded-md flex items-center gap-1"><Flame className="w-3 h-3"/> ~{dayBurn} kcal</span>
                          {settings.myzoneConnected && <span className="text-[10px] font-bold bg-rose-50 dark:bg-rose-900/20 text-rose-600 px-2 py-1 rounded-md flex items-center gap-1"><Radio className="w-3 h-3"/> {dayMeps} MEPs</span>}
                        </div>
                      )}
                    </div>
                    
                    {dayWorkouts.length > 0 ? (
                      <div className="flex flex-wrap gap-2 mt-2">
                        {Object.values(groupedWorkouts).map((group, idx) => group.ex ? (
                          <span key={idx} className="text-xs font-bold bg-slate-100 dark:bg-slate-900 text-slate-600 dark:text-slate-300 px-2 py-1 rounded-lg">
                            {group.count}x {group.ex.name}
                          </span>
                        ) : null)}
                      </div>
                    ) : (
                      <span className="text-xs font-medium text-slate-400 italic">Rest Day</span>
                    )}
                  </div>
                </div>
              </div>
            );
          })}
        </div>
      </div>
    );
  };

  return (
    <div className="min-h-screen bg-slate-50 dark:bg-slate-950 text-slate-900 dark:text-slate-100 font-sans selection:bg-emerald-100 pb-20">
      <div className="max-w-md mx-auto px-4 pt-8">
        
        {/* Header */}
        <div className="flex justify-between items-center mb-8">
          <div>
            <h1 className="text-2xl font-black tracking-tight text-slate-900 dark:text-white">FITNESS TRACKER</h1>
            <p className="text-emerald-600 font-bold text-xs uppercase tracking-widest mt-1">Mark's Training System</p>
          </div>
          <div className="w-12 h-12 bg-slate-900 dark:bg-emerald-600 rounded-2xl flex items-center justify-center shadow-lg shadow-emerald-500/20 rotate-3 transition-all duration-300">
            {activeTab === 'dashboard' && <Activity className="text-white w-6 h-6" />}
            {activeTab === 'train' && <Play className="text-white w-6 h-6 fill-current" />}
            {activeTab === 'body' && <Scale className="text-white w-6 h-6" />}
            {activeTab === 'nutrition' && <Apple className="text-white w-6 h-6" />}
            {activeTab === 'report' && <ClipboardList className="text-white w-6 h-6" />}
          </div>
        </div>

        {/* Content Area */}
        {activeTab === 'dashboard' && <Dashboard />}
        {activeTab === 'train' && <TrainTab />}
        {activeTab === 'body' && <BodyTab />}
        {activeTab === 'nutrition' && <NutritionTab />}
        {activeTab === 'report' && <ReportTab />}

        {/* Bottom Navigation */}
        <div className="fixed bottom-4 left-1/2 -translate-x-1/2 w-[98%] max-w-md bg-white/90 dark:bg-slate-900/90 backdrop-blur-xl border border-slate-200 dark:border-slate-800 rounded-3xl p-1.5 shadow-2xl flex justify-between items-center z-50">
          {[
            { id: 'dashboard', icon: Activity, label: 'Dash' },
            { id: 'train', icon: Dumbbell, label: 'Train' },
            { id: 'nutrition', icon: Apple, label: 'Diet' },
            { id: 'body', icon: Scale, label: 'Body' },
            { id: 'report', icon: ClipboardList, label: 'Review' }
          ].map(tab => (
            <button 
              key={tab.id}
              onClick={() => setActiveTab(tab.id)}
              className={`flex flex-col items-center justify-center flex-1 h-14 rounded-2xl transition-all duration-300 ${activeTab === tab.id ? 'bg-emerald-600 text-white shadow-md transform -translate-y-1' : 'text-slate-400 hover:text-slate-600 dark:hover:text-slate-200'}`}
            >
              <tab.icon className={`w-5 h-5 ${activeTab === tab.id ? 'mb-0.5' : ''}`} />
              <span className={`text-[9px] font-bold uppercase tracking-wider ${activeTab === tab.id ? 'block' : 'hidden sm:block'}`}>{tab.label}</span>
            </button>
          ))}
        </div>
      </div>
    </div>
  );
};

export default App;